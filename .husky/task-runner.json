{
   "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
   "tasks": [
      {
         "name": "dotnet-format-staged-files",
         "group": "pre-commit",
         "command": "dotnet",
         "args": [ "format", "Tempora.sln", "--include", "${staged}", "--verbosity", "minimal" ],
         "include": [ "**/*.cs" ]
      }
   ]
}
